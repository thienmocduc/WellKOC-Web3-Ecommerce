# ══════════════════════════════════════════════
# WellKOC Platform — Environment Configuration
# Copy to .env and fill in values
# ══════════════════════════════════════════════

# === APP ===
APP_NAME=WellKOC
APP_ENV=development
APP_VERSION=1.0.0
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# === DATABASE ===
POSTGRES_USER=wellkoc
POSTGRES_PASSWORD=wellkoc_dev_2026
POSTGRES_DB=wellkoc
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wellkoc:wellkoc_dev_2026@localhost:5432/wellkoc

# === REDIS ===
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# === ELASTICSEARCH ===
ELASTICSEARCH_URL=http://localhost:9200

# === BLOCKCHAIN (Polygon) ===
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_TESTNET_RPC=https://rpc-amoy.polygon.technology
WALLET_PRIVATE_KEY=your-deployer-wallet-private-key
COMMISSION_CONTRACT_ADDRESS=
DPP_FACTORY_ADDRESS=
WK_TOKEN_ADDRESS=

# === PAYMENTS ===
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key
PAYOS_CLIENT_ID=your_client_id
PAYOS_API_KEY=your_api_key
PAYOS_CHECKSUM_KEY=your_checksum_key

# === AI / ANTHROPIC ===
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# === AWS S3 / Storage ===
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=wellkoc-media
AWS_REGION=ap-southeast-1
CDN_BASE_URL=https://cdn.wellkoc.com

# === IPFS (for DPP NFT metadata) ===
PINATA_API_KEY=your_pinata_key
PINATA_SECRET=your_pinata_secret

# === NOTIFICATIONS ===
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE=+84000000000
FCM_SERVER_KEY=your_fcm_key

# === SHIPPING PARTNERS ===
GHN_TOKEN=your_ghn_token
GHN_SHOP_ID=your_shop_id
GHTK_TOKEN=your_ghtk_token

# === MONITORING ===
SENTRY_DSN=your_sentry_dsn

# === STRIPE (Membership billing) ===
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_webhook_secret
